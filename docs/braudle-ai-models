// Retry logic for Groq rate limit hits
export async function callGroqWithRetry(
  messages: Groq.ChatCompletionMessageParam[],
  model = GROQ_MODELS.smart,
  retries = 3
): Promise<string> {
  for (let attempt = 0; attempt < retries; attempt++) {
    try {
      return await callGroq(messages, model);
    } catch (err: any) {
      if (err.status === 429 && attempt < retries - 1) {
        // Exponential backoff: 1s, 2s, 4s
        await new Promise(r => setTimeout(r, Math.pow(2, attempt) * 1000));
        continue;
      }
      throw err;
    }
  }
  throw new Error('Groq rate limit exceeded after retries');
}
 
